---
<header class="border-b border-hairline bg-canvas/90 backdrop-blur-lg sticky top-0 z-40">
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 h-14 flex items-center justify-between">

    <!-- Logo -->
    <a href="/"
       class="flex items-center gap-2 group focus:outline-none focus-ring rounded-lg px-1.5 py-1 -ml-1.5">
      <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current text-error" aria-hidden="true">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 7.517 0 12 0 12s0 4.483.502 5.814a3.016 3.016 0 0 0 2.122 2.136C4.495 20.455 12 20.455 12 20.455s7.505 0 9.376-.505a3.015 3.015 0 0 0 2.122-2.136C24 16.483 24 12 24 12s0-4.483-.502-5.814z"/>
        <path d="M10.03 16.698v-6.862l5.49 3.43-5.49 3.43Z" fill="#fff"/>
      </svg>
      <div class="hidden md:block">
        <span class="text-body-sm-strong text-ink tracking-tight block leading-none">YouTube Playlist Length Calculator</span>
      </div>
      <div class="md:hidden">
        <span class="text-body-sm-strong text-ink tracking-tight block leading-none">YouTube Playlist Calculator</span>
      </div>
    </a>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <a href="https://paypal.me/cxtroexe" target="_blank" rel="noopener noreferrer"
         class="hidden md:flex items-center gap-2 px-3 h-8 rounded-lg border border-gradient-preview-start/40 bg-gradient-preview-start/10 hover:bg-gradient-preview-start/20 hover:border-gradient-preview-start/60 text-gradient-preview-end text-body-sm font-medium transition-all duration-200 focus:outline-none focus-ring whitespace-nowrap">
        <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10s10-4.477 10-10c0-5.523-4.477-10-10-10zm0 1.5c4.679 0 8.5 3.821 8.5 8.5S16.679 22 12 22 3.5 18.179 3.5 12 7.321 3.5 12 3.5zm5.5 10H9.5v-1h8v1zm0-2.5H9.5v-1h8v1zm0-2.5H9.5v-1h8v1z"/>
        </svg>
        <span>Fuel the code</span>
      </a>

      <a href="https://github.com/granthsh/yt-playlist-calc" target="_blank" rel="noopener noreferrer"
         class="w-8 h-8 rounded-lg border border-hairline hover:border-hairline-strong flex items-center justify-center bg-canvas-elevated hover:bg-canvas-elevated-2 text-mute hover:text-link transition-colors focus:outline-none focus-ring"
         aria-label="GitHub Repository">
        <svg viewBox="0 0 24 24" class="w-4.5 h-4.5 fill-current" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.305-.536-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.872.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>

      <button type="button" id="theme-toggle"
        class="w-8 h-8 rounded-lg border border-hairline hover:border-hairline-strong flex items-center justify-center bg-canvas-elevated hover:bg-canvas-elevated-2 text-mute hover:text-ink transition-colors focus:outline-none cursor-pointer focus-ring"
        aria-label="Toggle theme">
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current stroke-2 block dark:hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current stroke-2 hidden dark:block">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
