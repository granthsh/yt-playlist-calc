---
import Layout from "../layouts/Layout.astro";
import Footer from "./Footer.astro";

interface Props {
  activeTab: "calculator" | "thumbnail" | "deadline";
  ogImage?: string;
}

const { activeTab, ogImage = "/og-image.svg" } = Astro.props;

const meta = {
  calculator: {
    title: "YouTube Playlist Length Calculator | Advanced YT Playlist Tracker",
    description: "Calculate total YouTube playlist length instantly. Sort videos by length, likes, or date, and track private playlists. 100% free with zero limits!",
    canonicalUrl: "https://ytplaylistcalc.pro",
  },
  thumbnail: {
    title: "YouTube Thumbnail Downloader | HD Thumbnails Free",
    description: "Download any YouTube video or playlist thumbnail in maximum resolution (HD & 4K) instantly. Safe, fast, and no registration or login required.",
    canonicalUrl: "https://ytplaylistcalc.pro/youtube-thumbnail-downloader",
  },
  deadline: {
    title: "YouTube Playlist Deadline & Study Planner Tool",
    description: "Finish courses on time! Input your deadline to calculate exactly how many hours or videos you need to watch per day or session to complete your playlist.",
    canonicalUrl: "https://ytplaylistcalc.pro/deadline-planner",
  },
};

const currentMeta = meta[activeTab];
---

<Layout title={currentMeta.title} description={currentMeta.description} canonicalUrl={currentMeta.canonicalUrl} ogImage={ogImage}>
  <div class="min-h-screen flex flex-col pb-28">

    <!-- ── Header ──────────────────────────────────────────────────── -->
    <header class="border-b border-hairline bg-canvas/90 backdrop-blur-lg sticky top-0 z-40">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6 h-14 flex items-center justify-between">

        <!-- Logo -->
        <a href="/" data-tab-link="calculator"
           class="flex items-center gap-2 group focus:outline-none focus-ring rounded-lg px-1.5 py-1 -ml-1.5">
          <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current text-error" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 7.517 0 12 0 12s0 4.483.502 5.814a3.016 3.016 0 0 0 2.122 2.136C4.495 20.455 12 20.455 12 20.455s7.505 0 9.376-.505a3.015 3.015 0 0 0 2.122-2.136C24 16.483 24 12 24 12s0-4.483-.502-5.814z"/>
            <path d="M10.03 16.698v-6.862l5.49 3.43-5.49 3.43Z" fill="#fff"/>
          </svg>
          <div class="hidden md:block">
            <span class="text-body-sm-strong text-ink tracking-tight block leading-none">YouTube Playlist Length Calculator</span>
          </div>
          <div class="md:hidden">
            <span class="text-body-sm-strong text-ink tracking-tight block leading-none">YouTube Playlist Calculator</span>
          </div>
        </a>

        <!-- Right actions: Fuel the code + GitHub + Theme toggle -->
        <div class="flex items-center gap-2">
          <!-- Fuel the code (desktop only) -->
          <a href="https://paypal.me/cxtroexe" target="_blank" rel="noopener noreferrer"
             class="hidden md:flex items-center gap-2 px-3 h-8 rounded-lg border border-gradient-preview-start/40 bg-gradient-preview-start/10 hover:bg-gradient-preview-start/20 hover:border-gradient-preview-start/60 text-gradient-preview-end text-body-sm font-medium transition-all duration-200 focus:outline-none focus-ring whitespace-nowrap">
            <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10s10-4.477 10-10c0-5.523-4.477-10-10-10zm0 1.5c4.679 0 8.5 3.821 8.5 8.5S16.679 22 12 22 3.5 18.179 3.5 12 7.321 3.5 12 3.5zm5.5 10H9.5v-1h8v1zm0-2.5H9.5v-1h8v1zm0-2.5H9.5v-1h8v1z"/>
            </svg>
            <span>Fuel the code</span>
          </a>

          <!-- GitHub Link -->
          <a href="https://github.com/granthsh/yt-playlist-calc" target="_blank" rel="noopener noreferrer"
             class="w-8 h-8 rounded-lg border border-hairline hover:border-hairline-strong flex items-center justify-center bg-canvas-elevated hover:bg-canvas-elevated-2 text-mute hover:text-link transition-colors focus:outline-none focus-ring"
             aria-label="GitHub Repository">
            <svg viewBox="0 0 24 24" class="w-4.5 h-4.5 fill-current" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.305-.536-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.872.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>

          <button type="button" id="theme-toggle"
            class="w-8 h-8 rounded-lg border border-hairline hover:border-hairline-strong flex items-center justify-center bg-canvas-elevated hover:bg-canvas-elevated-2 text-mute hover:text-ink transition-colors focus:outline-none cursor-pointer focus-ring"
            aria-label="Toggle theme">
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current stroke-2 block dark:hidden">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current stroke-2 hidden dark:block">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- ── Main ────────────────────────────────────────────────────── -->
    <main class="flex-grow max-w-[1200px] w-full mx-auto px-4 md:px-6 py-8 md:py-12">

      <div id="panel-calculator" class={`tab-panel ${activeTab === "calculator" ? "block" : "hidden"}`}>
        <slot name="calculator" />
      </div>
      <div id="panel-thumbnail" class={`tab-panel ${activeTab === "thumbnail" ? "block" : "hidden"}`}>
        <slot name="thumbnail" />
      </div>
      <div id="panel-deadline" class={`tab-panel ${activeTab === "deadline" ? "block" : "hidden"}`}>
        <slot name="deadline" />
      </div>
    </main>

    <!-- ── Footer ─────────────────────────────────────────────────────── -->
    <Footer />

    <!-- ── Bottom Dock (Desktop) ───────────────────────────────── -->
    <nav class="hidden md:flex fixed bottom-6 left-1/2 -translate-x-1/2 z-50 w-full max-w-4xl px-4">
      <div class="relative bg-canvas-elevated/90 backdrop-blur-xl border border-hairline rounded-3xl p-2 flex items-center shadow-2xl">
        <!-- Active indicator -->
        <div id="desktop-nav-pill" class="absolute top-2 bottom-2 bg-primary/20 border border-primary/30 rounded-2xl transition-all duration-300 ease-in-out -z-10"></div>

        <a href="/" data-tab-link="calculator" id="desk-tab-calculator"
           class="desk-tab flex-1 flex flex-col items-center justify-center py-3.5 px-6 gap-2 rounded-2xl focus:outline-none focus-ring relative min-w-[140px]">
          <svg viewBox="0 0 24 24" class="w-6 h-6 fill-none stroke-current stroke-2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M8 8h8M8 16h5"/></svg>
          <span class="text-xs font-medium leading-none text-center whitespace-nowrap">Playlist Length</span>
        </a>
        <a href="/youtube-thumbnail-downloader" data-tab-link="thumbnail" id="desk-tab-thumbnail"
           class="desk-tab flex-1 flex flex-col items-center justify-center py-3.5 px-6 gap-2 rounded-2xl focus:outline-none focus-ring relative min-w-[140px]">
          <svg viewBox="0 0 24 24" class="w-6 h-6 fill-none stroke-current stroke-2"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          <span class="text-xs font-medium leading-none text-center whitespace-nowrap">Thumbnail Grabber</span>
        </a>
        <a href="/deadline-planner" data-tab-link="deadline" id="desk-tab-deadline"
           class="desk-tab flex-1 flex flex-col items-center justify-center py-3.5 px-6 gap-2 rounded-2xl focus:outline-none focus-ring relative min-w-[140px]">
          <svg viewBox="0 0 24 24" class="w-6 h-6 fill-none stroke-current stroke-2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          <span class="text-xs font-medium leading-none text-center whitespace-nowrap">Deadline Planner</span>
        </a>
      </div>
    </nav>

    <!-- ── Bottom Dock (Mobile) ────────────────────────────────────── -->
    <nav class="md:hidden fixed bottom-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-sm px-4">
      <div class="relative bg-canvas-elevated/90 backdrop-blur-xl border border-hairline rounded-3xl p-2 flex items-center shadow-2xl">
        <!-- Active indicator -->
        <div id="nav-pill" class="absolute top-2 bottom-2 bg-primary/20 border border-primary/30 rounded-2xl transition-all duration-300 ease-in-out -z-10"></div>

        <a href="/" data-tab-link="calculator" id="mob-tab-calculator"
           class="mob-tab flex-1 flex flex-col items-center justify-center py-3 px-4 gap-1.5 rounded-2xl focus:outline-none min-w-[100px]">
          <svg viewBox="0 0 24 24" class="w-5.5 h-5.5 fill-none stroke-current stroke-2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M8 8h8M8 16h5"/></svg>
          <span class="text-xs font-medium leading-none text-center">Playlist Length</span>
        </a>
        <a href="/youtube-thumbnail-downloader" data-tab-link="thumbnail" id="mob-tab-thumbnail"
           class="mob-tab flex-1 flex flex-col items-center justify-center py-3 px-4 gap-1.5 rounded-2xl focus:outline-none min-w-[100px]">
          <svg viewBox="0 0 24 24" class="w-5.5 h-5.5 fill-none stroke-current stroke-2"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          <span class="text-xs font-medium leading-none text-center">Thumbnail Grabber</span>
        </a>
        <a href="/deadline-planner" data-tab-link="deadline" id="mob-tab-deadline"
           class="mob-tab flex-1 flex flex-col items-center justify-center py-3 px-4 gap-1.5 rounded-2xl focus:outline-none min-w-[100px]">
          <svg viewBox="0 0 24 24" class="w-5.5 h-5.5 fill-none stroke-current stroke-2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          <span class="text-xs font-medium leading-none text-center">Deadline Planner</span>
        </a>
      </div>
    </nav>

  </div>
</Layout>

<script>
  type TabKey = "calculator" | "thumbnail" | "deadline";
  const tabs: Record<TabKey, { panelId: string; path: string; title: string; description: string }> = {
    calculator: {
      panelId: "panel-calculator", path: "/",
      title: "YouTube Playlist Length Calculator | Advanced YT Playlist Tracker",
      description: "Calculate total YouTube playlist length instantly. Sort videos by length, likes, or date, and track private playlists. 100% free with zero limits!"
    },
    thumbnail: {
      panelId: "panel-thumbnail", path: "/youtube-thumbnail-downloader",
      title: "YouTube Thumbnail Downloader | HD Thumbnails Free",
      description: "Download any YouTube video or playlist thumbnail in maximum resolution (HD & 4K) instantly. Safe, fast, and no registration or login required."
    },
    deadline: {
      panelId: "panel-deadline", path: "/deadline-planner",
      title: "YouTube Playlist Deadline & Study Planner Tool",
      description: "Finish courses on time! Input your deadline to calculate exactly how many hours or videos you need to watch per day or session to complete your playlist."
    },
  };

  // Theme toggle
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });

  // Determine current tab from URL
  function currentTab(): TabKey {
    const path = window.location.pathname;
    if (path.startsWith("/youtube-thumbnail-downloader")) return "thumbnail";
    if (path.startsWith("/deadline-planner")) return "deadline";
    return "calculator";
  }

  // Switch tab
  function switchTab(key: TabKey, push = true) {
    // Scroll to top
    window.scrollTo(0, 0);

    // Panels
    Object.keys(tabs).forEach(k => {
      const p = document.getElementById(tabs[k as TabKey].panelId);
      if (p) p.classList.toggle("hidden", k !== key);
    });

    // Update URL + SEO
    if (push) window.history.pushState({ tab: key }, "", tabs[key].path);
    document.title = tabs[key].title;
    document.querySelector('meta[name="description"]')?.setAttribute("content", tabs[key].description);

    // Style desktop tabs (bottom dock) - active state
    document.querySelectorAll(".desk-tab").forEach(el => {
      const a = el as HTMLElement;
      const isActive = a.dataset.tabLink === key;
      a.classList.toggle("bg-primary", isActive);
      a.classList.toggle("text-on-primary", isActive);
      a.classList.toggle("shadow-sm", isActive);
      a.classList.toggle("text-body", !isActive);
    });

    // Move desktop pill indicator
    const deskPill = document.getElementById("desktop-nav-pill");
    const activeDeskTab = document.querySelector(`.desk-tab[data-tab-link="${key}"]`) as HTMLElement;
    if (activeDeskTab && deskPill) {
      deskPill.style.width  = `${activeDeskTab.offsetWidth}px`;
      deskPill.style.left   = `${activeDeskTab.offsetLeft}px`;
    }

    // Style mobile tabs + move pill
    const allMob = document.querySelectorAll(".mob-tab") as NodeListOf<HTMLElement>;
    const navPill = document.getElementById("nav-pill");
    allMob.forEach(el => {
      const isActive = el.dataset.tabLink === key;
      el.classList.toggle("text-ink", isActive);
      el.classList.toggle("text-mute", !isActive);
      if (isActive && navPill) {
        navPill.style.width  = `${el.offsetWidth}px`;
        navPill.style.left   = `${el.offsetLeft}px`;
      }
    });
  }

  // Tab link clicks
  document.querySelectorAll("[data-tab-link]").forEach(el => {
    el.addEventListener("click", e => {
      e.preventDefault();
      switchTab((el as HTMLElement).dataset.tabLink as TabKey);
    });
  });

  // Browser back/forward
  window.addEventListener("popstate", () => switchTab(currentTab(), false));

  // Init
  switchTab(currentTab(), false);

  // Recalculate pill on resize
  window.addEventListener("resize", () => switchTab(currentTab(), false));
  setTimeout(() => switchTab(currentTab(), false), 150);
</script>
