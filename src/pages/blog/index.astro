---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout
  title="Guides & Tutorials - YouTube Playlist Calculator | ytplaylistcalc.pro"
  description="Learn how to calculate YouTube playlist length, sort videos, download HD thumbnails, plan study deadlines, and fix API quota limits with our free guides."
  canonicalUrl="https://ytplaylistcalc.pro/blog"
  ogType="website"
>
  <div class="relative w-full min-h-screen flex flex-col">
    <Header />
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-full max-w-5xl h-[400px] bg-radial-[at_50%_0%] from-gradient-develop-start/10 via-transparent to-transparent -z-10 blur-3xl pointer-events-none"></div>

    <div class="max-w-5xl mx-auto w-full px-4 py-12 flex-grow">
      <!-- Hero -->
      <div class="text-center max-w-2xl mx-auto mb-12">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-hairline bg-canvas-elevated-2 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-gradient-develop-end animate-pulse"></span>
          <span class="text-caption-mono text-mute">Blog & Guides</span>
        </div>
        <h1 class="text-display-lg md:text-display-xl text-ink tracking-tighter mb-4 text-balance">
          Guides & Tutorials
        </h1>
        <p class="text-body-md text-body text-pretty">
          Learn how to get the most out of your YouTube playlists — from calculating total duration and sorting videos, to planning study schedules and downloading HD thumbnails.
        </p>
      </div>

      <!-- Posts Grid -->
      <div class="grid gap-6 md:grid-cols-2">
        {posts.map(post => (
          <a
            href={`/blog/${post.id}/`}
            class="group bg-canvas-elevated border border-hairline hover:border-hairline-strong rounded-xl p-6 transition-all duration-200 hover:-translate-y-0.5 focus:outline-none focus-ring"
          >
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.tags.slice(0, 2).map(tag => (
                <span class="px-2 py-0.5 rounded-full bg-canvas-elevated-2 border border-hairline text-caption-mono text-mute text-[11px]">{tag}</span>
              ))}
            </div>
            <h2 class="text-body-md-strong text-ink group-hover:text-link transition-colors mb-2 line-clamp-2">{post.data.title}</h2>
            <p class="text-body-sm text-mute mb-4 line-clamp-2">{post.data.description}</p>
            <div class="flex items-center gap-3 text-caption-mono text-mute text-[12px]">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
              </time>
              <span class="text-link group-hover:underline font-medium">Read more →</span>
            </div>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-body-md text-mute">No guides yet. Check back soon!</p>
        </div>
      )}
    </div>
  </div>
  <Footer />
</Layout>
