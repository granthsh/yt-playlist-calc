---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout 
  title="About Us - YouTube Playlist Duration Calculator"
  description="Learn more about ytplaylistcalc.pro. Discover how our privacy-first tools help creators and students track durations, plan deadlines, and sort videos."
  canonicalUrl="https://ytplaylistcalc.pro/about"
/>

<script type="application/ld+json" set:html={JSON.stringify([{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About YouTube Playlist Length Calculator",
  "description": "Free, privacy-first tools for YouTube creators and viewers — calculate playlist duration, download thumbnails, plan study schedules."
},
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "YouTube Playlist Length Calculator",
  "url": "https://ytplaylistcalc.pro",
  "description": "Free, privacy-first YouTube playlist tools — calculate duration, download HD thumbnails, plan study deadlines.",
  "logo": "https://ytplaylistcalc.pro/og-image.svg",
  "sameAs": [
    "https://github.com/granthsh/yt-playlist-calc",
    "https://www.linkedin.com/in/granthsh/"
  ]
}], null, 2)}></script>
---

<div class="relative w-full min-h-screen flex flex-col">
  <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-full max-w-5xl h-[400px] bg-radial-[at_50%_0%] from-gradient-develop-start/10 via-transparent to-transparent -z-10 blur-3xl pointer-events-none"></div>

  <!-- Hero -->
  <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-hairline bg-canvas-elevated-2 mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-gradient-develop-end animate-pulse"></span>
      <span class="text-caption-mono text-mute">About Us</span>
    </div>
    <h1 class="text-display-lg md:text-display-xl text-ink tracking-tighter mb-4 text-balance">
      Built for Learners, by a Learner
    </h1>
    <p class="text-body-md text-body text-pretty">
      A free, open-source toolkit for YouTube creators and viewers — no ads, no tracking, no compromises.
    </p>
  </div>

  <div class="max-w-3xl mx-auto space-y-12 flex-grow">
    <!-- Origin Story -->
    <section>
      <h2 class="text-display-sm text-ink font-semibold mb-4 pb-3 border-b border-hairline">Why This Exists</h2>
      <div class="prose prose-invert max-w-none text-body space-y-4">
        <p>I built this because I was frustrated. I'd find a great YouTube course or playlist, want to know how long it would take to finish, and there was no easy way to find out. YouTube shows individual video lengths, but not the total — and certainly not at 1.5x or 2x speed.</p>
        <p>Existing "playlist length calculators" were cluttered with ads, required sign-ups, tracked users, or simply didn't work well with large playlists. So I built my own — clean, fast, and completely free.</p>
        <p>What started as a simple duration calculator grew into three tools that I use myself every week.</p>
      </div>
    </section>

    <!-- The Toolkit -->
    <section>
      <h2 class="text-display-sm text-ink font-semibold mb-4 pb-3 border-b border-hairline">The Toolkit</h2>
      <div class="prose prose-invert max-w-none text-body space-y-6">
        <article class="bg-canvas-elevated border border-hairline rounded-xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-develop-start/10 flex items-center justify-center shrink-0">
              <svg viewBox="0 0 24 24" class="w-6 h-6 fill-none stroke-current stroke-2 text-gradient-develop-end" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M8 8h8M8 16h5"/>
              </svg>
            </div>
            <div>
              <h3 class="text-body-md-strong text-ink mb-2">Playlist Length Calculator</h3>
              <p class="text-body text-body-sm text-mute">Calculate total duration of any public YouTube playlist. Supports multiple playlists, custom playback speeds (0.1x–10x), video range selection, search & sort, and watch progress tracking.</p>
            </div>
          </div>
        </article>

        <article class="bg-canvas-elevated border border-hairline rounded-xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-preview-start/10 flex items-center justify-center shrink-0">
              <svg viewBox="0 0 24 24" class="w-6 h-6 fill-none stroke-current stroke-2 text-gradient-preview-end" aria-hidden="true">
                <rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
              </svg>
            </div>
            <div>
              <h3 class="text-body-md-strong text-ink mb-2">Thumbnail Grabber</h3>
              <p class="text-body text-body-sm text-mute">Download YouTube thumbnails in all available resolutions — MaxRes (1920×1080), SD, HQ, MQ. No login, no watermarks, direct from YouTube's CDN.</p>
            </div>
          </div>
        </article>

        <article class="bg-canvas-elevated border border-hairline rounded-xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-ship-start/10 flex items-center justify-center shrink-0">
              <svg viewBox="0 0 24 24" class="w-6 h-6 fill-none stroke-current stroke-2 text-gradient-ship-end" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/>
              </svg>
            </div>
            <div>
              <h3 class="text-body-md-strong text-ink mb-2">Deadline Planner</h3>
              <p class="text-body text-body-sm text-mute">Plan exactly how much to watch per day to finish a playlist by your deadline. Set custom speeds, multiple sessions per day, and see a speed matrix comparing daily watch time at different speeds.</p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Philosophy -->
    <section>
      <h2 class="text-display-sm text-ink font-semibold mb-4 pb-3 border-b border-hairline">Core Principles</h2>
      <div class="prose prose-invert max-w-none text-body space-y-6">
        <article class="bg-canvas-elevated border border-hairline rounded-xl p-6">
          <h3 class="text-body-md-strong text-ink mb-3 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-link" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            100% Free, Forever
          </h3>
          <p class="text-body text-mute">No ads, no premium tiers, no feature gates, no upsells. The tools are completely free because knowledge shouldn't be paywalled.</p>
        </article>

        <article class="bg-canvas-elevated border border-hairline rounded-xl p-6">
          <h3 class="text-body-md-strong text-ink mb-3 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-link" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Privacy First
          </h3>
          <p class="text-body text-mute">Zero tracking, zero analytics, zero cookies. All processing happens in your browser. We never see your playlists, watch history, or deadlines.</p>
        </article>

        <article class="bg-canvas-elevated border border-hairline rounded-xl p-6">
          <h3 class="text-body-md-strong text-ink mb-3 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-link" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            Community Driven
          </h3>
          <p class="text-body text-mute">Open source under MIT License. Bug reports, feature requests, and PRs welcome. Built in the open for the community.</p>
        </article>

        <article class="bg-canvas-elevated border border-hairline rounded-xl p-6">
          <h3 class="text-body-md-strong text-ink mb-3 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-link" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            No Vendor Lock-in
          </h3>
          <p class="text-body text-mute">No accounts, no subscriptions, no data export needed because there's no data to export. Your data stays in your browser, always.</p>
        </article>
      </div>
    </section>

    <!-- Tech Stack -->
    <section>
      <h2 class="text-display-sm text-ink font-semibold mb-4 pb-3 border-b border-hairline">Tech Stack</h2>
      <div class="prose prose-invert max-w-none text-body">
        <p class="mb-4">Built with modern, privacy-respecting technologies:</p>
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="px-3 py-1 bg-canvas-elevated border border-hairline rounded-full text-sm text-body-sm">Astro 5</span>
          <span class="px-3 py-1 bg-canvas-elevated border border-hairline rounded-full text-sm text-body-sm">TypeScript</span>
          <span class="px-3 py-1 bg-canvas-elevated border border-hairline rounded-full text-sm text-body-sm">Tailwind CSS 4</span>
          <span class="px-3 py-1 bg-canvas-elevated border border-hairline rounded-full text-sm text-body-sm">Vanilla JS</span>
          <span class="px-3 py-1 bg-canvas-elevated border border-hairline rounded-full text-sm text-body-sm">YouTube Data API v3</span>
        </div>
        <ul class="list-disc list-inside space-y-2 pl-4 text-body text-mute">
          <li>Static site generation (SSG) — no server, no runtime</li>
          <li>Zero runtime framework overhead — ships minimal JS</li>
          <li>Content Security Policy enforced</li>
          <li>Automated dependency updates via Dependabot</li>
        </ul>
      </div>
    </section>

    <!-- The Creator -->
    <section>
      <h2 class="text-display-sm text-ink font-semibold mb-4 pb-3 border-b border-hairline">The Creator</h2>
      <div class="prose prose-invert max-w-none text-body space-y-4">
        <div class="bg-canvas-elevated border border-hairline rounded-xl p-6 md:flex md:items-center md:gap-6">
          <div class="w-24 h-24 md:w-32 md:h-32 rounded-full bg-gradient-develop-start/10 flex items-center justify-center shrink-0 mx-auto md:mx-0">
            <svg viewBox="0 0 24 24" class="w-10 h-10 md:w-14 md:h-14 fill-gradient-develop-end" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10s10-4.477 10-10c0-5.523-4.477-10-10-10zm0 1.5c4.679 0 8.5 3.821 8.5 8.5S16.679 22 12 22 3.5 18.179 3.5 12 7.321 3.5 12 3.5zm5.5 10H9.5v-1h8v1zm0-2.5H9.5v-1h8v1zm0-2.5H9.5v-1h8v1z"/>
            </svg>
          </div>
          <div class="text-center md:text-left mt-4 md:mt-0">
            <h3 class="text-display-sm text-ink font-semibold">Granth</h3>
            <p class="text-body text-mute mt-1">Developer & lifelong learner</p>
            <p class="text-body text-body-sm mt-4 max-w-xs mx-auto md:mx-0">
              I build tools I wish existed. This project started as a personal need and grew into something I hope helps other learners and creators. When I'm not coding, you'll find me exploring new tech, reading, or planning the next project.
            </p>
            <div class="flex items-center justify-center md:justify-start gap-4 mt-4">
              <a href="https://github.com/granthsh" target="_blank" rel="noopener" class="w-9 h-9 rounded-lg border border-hairline hover:border-hairline-strong flex items-center justify-center bg-canvas-elevated hover:bg-canvas-elevated-2 text-mute hover:text-link transition-colors focus:outline-none focus-ring" aria-label="GitHub">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.305-.536-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.872.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              </a>
              <a href="https://www.linkedin.com/in/granthsh/" target="_blank" rel="noopener" class="w-9 h-9 rounded-lg border border-hairline hover:border-hairline-strong flex items-center justify-center bg-canvas-elevated hover:bg-canvas-elevated-2 text-mute hover:text-link transition-colors focus:outline-none focus-ring" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 21.571V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="text-center mt-16 pt-8 border-t border-hairline">
      <h3 class="text-display-sm text-ink font-semibold mb-4">Explore the Tools</h3>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary font-medium rounded-lg transition-all duration-200 hover:opacity-90 active:scale-[0.98] focus:outline-none focus-ring whitespace-nowrap">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M8 8h8M8 16h5"/></svg>
          <span>Playlist Length Calculator</span>
        </a>
        <a href="/youtube-thumbnail-downloader" class="inline-flex items-center gap-2 px-6 py-3 border border-hairline hover:border-hairline-strong text-ink font-medium rounded-lg transition-colors focus:outline-none focus-ring whitespace-nowrap">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2" aria-hidden="true"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          <span>Thumbnail Grabber</span>
        </a>
        <a href="/deadline-planner" class="inline-flex items-center gap-2 px-6 py-3 border border-hairline hover:border-hairline-strong text-ink font-medium rounded-lg transition-colors focus:outline-none focus-ring whitespace-nowrap">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          <span>Deadline Planner</span>
        </a>
      </div>
    </div>
  </div>
  <Footer />
</div>