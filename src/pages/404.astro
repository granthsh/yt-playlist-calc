---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Page Not Found (404) | YouTube Playlist Length Calculator"
  description="The page you are looking for does not exist or has been moved. Return to the YouTube Playlist Length Calculator to calculate total playlist duration, download HD thumbnails, or plan your study deadlines."
  canonicalUrl="https://ytplaylistcalc.pro/404"
  noindex
/>

<div class="relative w-full min-h-screen flex flex-col px-4 md:px-6">
  <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-full max-w-5xl h-[400px] bg-radial-[at_50%_0%] from-gradient-develop-start/10 via-transparent to-transparent -z-10 blur-3xl pointer-events-none"></div>

  <div class="flex-grow flex items-center justify-center">
    <div class="text-center max-w-xl mx-auto py-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-hairline bg-canvas-elevated-2 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-error animate-pulse"></span>
        <span class="text-caption-mono text-mute">Error 404</span>
      </div>

      <p class="text-display-xl md:text-[6rem] font-semibold text-ink tracking-tighter leading-none mb-4">404</p>

      <h1 class="text-display-md md:text-display-lg text-ink tracking-tight mb-4 text-balance">
        This page went missing
      </h1>
      <p class="text-body-md text-body text-pretty mb-10">
        The page you're looking for doesn't exist, was moved, or the link is broken. Let's get you back to calculating.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary font-medium rounded-lg transition-all duration-200 hover:opacity-90 active:scale-[0.98] focus:outline-none focus-ring whitespace-nowrap">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M8 8h8M8 16h5"/></svg>
          <span>Playlist Length Calculator</span>
        </a>
        <a href="/youtube-thumbnail-downloader" class="inline-flex items-center gap-2 px-6 py-3 border border-hairline hover:border-hairline-strong text-ink font-medium rounded-lg transition-colors focus:outline-none focus-ring whitespace-nowrap">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2" aria-hidden="true"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          <span>Thumbnail Grabber</span>
        </a>
        <a href="/deadline-planner" class="inline-flex items-center gap-2 px-6 py-3 border border-hairline hover:border-hairline-strong text-ink font-medium rounded-lg transition-colors focus:outline-none focus-ring whitespace-nowrap">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-none stroke-current stroke-2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          <span>Deadline Planner</span>
        </a>
      </div>

      <p class="text-body-sm text-mute mt-8">
        Need help? <a href="/contact" class="text-link hover:underline">Contact us</a> or check the <a href="/faq" class="text-link hover:underline">FAQ</a>.
      </p>
    </div>
  </div>

  <Footer />
</div>
</Layout>
